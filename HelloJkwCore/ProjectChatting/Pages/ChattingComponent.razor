@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using TableViewerBlazor
@using ProjectChatting.Models
@inherits JkwPageBase

<div class="chat-wrapper">
    <div class="chat-header">
        채팅
        <span style="font-weight: normal; font-size: 0.8em; color: #666; margin-left: 8px;">
            (총 메세지: @Messages.Count)
        </span>
    </div>

    <div class="chat-messages" @ref="chatContainer">
        @foreach (var msg in Messages)
        {
            @if (IsSystem(msg))
            {
                <div class="message-row system">
                    <div class="system-message">@msg.Content</div>
                </div>
            }
            else
            {
                var isMine = IsMine(msg);
                <div class="message-row @(isMine ? "mine" : "other")">
                    @if (!isMine)
                    {
                        <div class="sender-name">@msg.SenderName</div>
                    }
                    <div class="message-bubble">
                        @msg.Content
                        <div class="message-time">@msg.SentAt.Humanize()</div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="input-area">
        <EditForm Model="newMessage" OnSubmit="@(async () => await SendMessageAsync())">
            <MudTextField @bind-Value="newMessage.Message" 
                            DebounceInterval="1000"
                          Placeholder="메세지를 입력하세요" 
                          Class="chat-input-mud"
                           />
            <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                Disabled="@string.IsNullOrWhiteSpace(newMessage.Message)"
                OnClick="@(async () => await SendMessageAsync())"
                Class="send-mud-button" />
        </EditForm>
    </div>
</div>

<script>
    window.scrollToBottom = (el) => { if (el) { el.scrollTop = el.scrollHeight; } };
</script>

@code {
    private bool IsSystem(ProjectChatting.Models.ChatMessage msg) => msg.Sender.Id == "system";
    private bool IsMine(ProjectChatting.Models.ChatMessage msg) => User?.Id == msg.Sender;
}
