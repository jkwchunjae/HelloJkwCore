@page "/"
@inherits JkwPageBase
@using ProjectChatting
@using ProjectChatting.Pages
@inject ChattingService ChattingService

<PageTitle>HelloJkw</PageTitle>

@if (IsAuthenticated)
{
    <MudText Typo="Typo.h4">안녕하세요, @User!.DisplayName 님.</MudText>
    <AuthorizeView Roles="DiaryWriter">
        <Authorized>
            <MudButton
                Href="diary"
                StartIcon="@Icons.Material.Filled.MenuBook"
                Variant="Variant.Outlined"
                Color="Color.Dark"
            >
                일기장
            </MudButton>
        </Authorized>
    </AuthorizeView>
}
else
{
    <MudText Typo="Typo.h4">안녕하세요.</MudText>

    <MudButton Href="/account/login"
        Variant="Variant.Outlined"
        Size="Size.Large"
    >
        로그인
    </MudButton>
}

@if (_room != null && User != null)
{
    <ChattingComponent Room="_room" />
}

@code {
    ChattingRoom? _room;
    protected override Task OnPageInitializedAsync()
    {
        _room = ChattingService.CreateOrGetRoom(new RoomName($"{nameof(HelloJkwCore)}_{nameof(Home)}"));

        return Task.CompletedTask;
    }
}
