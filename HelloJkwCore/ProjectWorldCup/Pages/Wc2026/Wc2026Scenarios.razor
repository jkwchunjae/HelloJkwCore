@inherits JkwPageBase
@layout WcLayout
@page "/worldcup/2026/scenario"

<WcTitle>경우의 수</WcTitle>

@if (Error != null)
{
  <MudAlert Severity="Severity.Error" Class="scenario-alert">
    경기 데이터를 불러오지 못했습니다. @Error.Message
  </MudAlert>
}
else if (!Groups.Any())
{
  <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="scenario-loading" />
}
else
{
  @if (SaveError != null)
  {
    <MudAlert Severity="Severity.Warning" Class="scenario-alert">
      입력한 점수를 저장하지 못했습니다. @SaveError.Message
    </MudAlert>
  }

  <MudAlert Severity="Severity.Info" Class="scenario-alert">
    @if (IsAuthenticated)
    {
      <span>자동으로 저장됩니다.</span>
    }
    else
    {
      <span>로그인을 하면 점수가 저장됩니다.</span>
      <MudLink Href="/login?ReturnUrl=/worldcup/2026/scenario" Underline="Underline.Always">로그인</MudLink>
    }
  </MudAlert>

  <div class="scenario-simulation-toggle">
    <MudTooltip Text="1라운드 내기 시뮬레이션 열기/닫기">
      <MudIconButton Icon="@(SimulationPanelOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Leaderboard)"
                     Color="Color.Primary"
                     Variant="Variant.Filled"
                     aria-label="1라운드 내기 시뮬레이션 열기/닫기"
                     OnClick="@ToggleSimulationPanel" />
    </MudTooltip>
    <MudTooltip Text="32강 토너먼트 시뮬레이션 열기/닫기">
      <MudIconButton Icon="@(Round32SimulationPanelOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.AccountTree)"
                     Color="Color.Secondary"
                     Variant="Variant.Filled"
                     aria-label="32강 토너먼트 시뮬레이션 열기/닫기"
                     OnClick="@ToggleRound32SimulationPanel" />
    </MudTooltip>
  </div>

  @if (SimulationPanelOpen)
  {
    <aside class="scenario-simulation-panel" aria-label="1라운드 내기 시뮬레이션">
      <div class="scenario-simulation-header">
        <div>
          <div class="scenario-simulation-title">1라운드 내기 시뮬레이션</div>
          <div class="scenario-simulation-subtitle">현재 경우의 수 기준, 저장되지 않음</div>
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       aria-label="시뮬레이션 접기"
                       OnClick="@ToggleSimulationPanel" />
      </div>

      @if (!SimulationLoaded)
      {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
      }
      else if (SimulationError != null)
      {
        <MudAlert Severity="Severity.Warning" Dense="true">
          내기 데이터를 불러오지 못했습니다. @SimulationError.Message
        </MudAlert>
      }
      else if (!SimulatedBettingRows.Any())
      {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
          아직 표시할 1라운드 내기 데이터가 없습니다.
        </MudText>
      }
      else
      {
        <MudTable T="IWcBettingItem<ITeam>"
                  Items="@SimulatedBettingRows"
                  Dense="true"
                  Hover="true"
                  Breakpoint="Breakpoint.None"
                  Elevation="0"
                  Class="scenario-table scenario-simulation-table">
          <HeaderContent>
            <MudTh Class="scenario-sim-rank-cell">#</MudTh>
            <MudTh>닉네임</MudTh>
            <MudTh Class="scenario-sim-success-cell">성공/실패</MudTh>
            <MudTh Class="scenario-sim-score-cell">점수</MudTh>
            <MudTh Class="scenario-sim-reward-cell">상금</MudTh>
          </HeaderContent>
          <RowTemplate>
            <MudTd DataLabel="#" Class="scenario-sim-rank-cell">@context.Rank</MudTd>
            <MudTd DataLabel="닉네임">
              <div class="scenario-sim-user">
                <span>@context.User.DisplayName</span>
                @if (context.User == User)
                {
                  <span class="scenario-sim-badge">나</span>
                }
                @if (context.IsRandom)
                {
                  <span class="scenario-sim-badge">랜덤</span>
                }
                @if (context.IsAi)
                {
                  <span class="scenario-sim-badge">AI</span>
                }
              </div>
            </MudTd>
            <MudTd DataLabel="성공/실패" Class="scenario-sim-success-cell">
              <div class="scenario-sim-teams scenario-sim-teams-success">
                @foreach (var team in context.Success)
                {
                  <img src="@team.Flag?.Replace("sq-2", "sq-1")" alt="@team.Name" title="@team.Name" />
                }
              </div>
              <div class="scenario-sim-teams scenario-sim-teams-fail">
                @foreach (var team in context.Fail)
                {
                  <img src="@team.Flag?.Replace("sq-2", "sq-1")" alt="@team.Name" title="@team.Name" />
                }
              </div>
            </MudTd>
            <MudTd DataLabel="점수" Class="scenario-sim-score-cell">@context.Score</MudTd>
            <MudTd DataLabel="상금" Class="scenario-sim-reward-cell">@context.Reward</MudTd>
          </RowTemplate>
        </MudTable>
      }
    </aside>
  }

  @if (Round32SimulationPanelOpen)
  {
    <aside class="scenario-simulation-panel scenario-round32-panel" aria-label="32강 토너먼트 시뮬레이션">
      <div class="scenario-simulation-header">
        <div>
          <div class="scenario-simulation-title">32강 토너먼트 시뮬레이션</div>
          <div class="scenario-simulation-subtitle">
            @if (Round32Simulation.CanSimulate)
            {
              <span>3위팀 조합 #@Round32Simulation.CombinationNumber · 현재 경우의 수 기준</span>
            }
            else
            {
              <span>현재 경우의 수 기준</span>
            }
          </div>
        </div>
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       aria-label="32강 시뮬레이션 접기"
                       OnClick="@ToggleRound32SimulationPanel" />
      </div>

      @if (!Round32Simulation.CanSimulate)
      {
        <MudAlert Severity="Severity.Info" Dense="true">
          @Round32Simulation.BlockReason
        </MudAlert>
      }
      else
      {
        <div class="scenario-round32-meta">
          <span>3위 진출 조</span>
          <strong>@string.Join(", ", Round32Simulation.ThirdPlaceGroups)</strong>
        </div>
        <MudTable T="Wc2026Round32SimulationMatch"
                  Items="@Round32Simulation.Matches"
                  Dense="true"
                  Hover="true"
                  Breakpoint="Breakpoint.None"
                  Elevation="0"
                  Class="scenario-table scenario-round32-table">
          <HeaderContent>
            <MudTh Class="scenario-round32-match-cell">경기</MudTh>
            <MudTh>홈</MudTh>
            <MudTh Class="scenario-round32-vs-cell"></MudTh>
            <MudTh>원정</MudTh>
          </HeaderContent>
          <RowTemplate>
            <MudTd DataLabel="경기" Class="scenario-round32-match-cell">@context.MatchNumber</MudTd>
            <MudTd DataLabel="홈">
              <div class="scenario-team scenario-round32-team">
                <span class="scenario-round32-slot">@context.HomeSlot</span>
                @if (!string.IsNullOrWhiteSpace(context.HomeTeam?.Flag))
                {
                  <img src="@context.HomeTeam.Flag" alt="" />
                }
                <span>@context.HomeTeam?.Name</span>
              </div>
            </MudTd>
            <MudTd Class="scenario-round32-vs-cell">vs</MudTd>
            <MudTd DataLabel="원정">
              <div class="scenario-team scenario-round32-team">
                <span class="scenario-round32-slot">@context.AwaySlot</span>
                @if (!string.IsNullOrWhiteSpace(context.AwayTeam?.Flag))
                {
                  <img src="@context.AwayTeam.Flag" alt="" />
                }
                <span>@context.AwayTeam?.Name</span>
              </div>
            </MudTd>
          </RowTemplate>
        </MudTable>
      }
    </aside>
  }

  <div class="scenario-page">
    @foreach (var group in Groups)
    {
      <section class="scenario-group">
        <div class="scenario-group-title">@group.Name</div>
        <div class="scenario-group-grid">
          <div class="scenario-matches">
            <div class="scenario-panel-title">남은 경기</div>
            <MudTable T="Wc2026ScenarioMatch"
                      Items="@group.RemainingMatches"
                      Dense="true"
                      Hover="true"
                      Breakpoint="Breakpoint.None"
                      Elevation="0"
                      Class="scenario-table scenario-match-table">
              <HeaderContent>
                <MudTh Class="scenario-team-header">홈</MudTh>
                <MudTh Class="scenario-score-header"></MudTh>
                <MudTh Class="scenario-score-divider"></MudTh>
                <MudTh Class="scenario-score-header"></MudTh>
                <MudTh Class="scenario-team-header">원정</MudTh>
              </HeaderContent>
              <RowTemplate>
                <MudTd DataLabel="홈" Class="scenario-team-cell">
                  <div class="scenario-team scenario-team-home">
                    @if (!string.IsNullOrWhiteSpace(context.HomeTeam.Flag))
                    {
                      <img src="@context.HomeTeam.Flag" alt="" />
                    }
                    <span>@context.HomeTeam.Name</span>
                  </div>
                </MudTd>
                <MudTd Class="scenario-score-cell">
                  <button type="button"
                          class="scenario-score-touch-button scenario-home-score-button"
                          aria-label="@($"{context.HomeTeam.Name} 득점 올리기")"
                          @onclick="(() => OnScoreIncrement(context, true))">
                    @context.HomeScore
                  </button>
                </MudTd>
                <MudTd Class="scenario-score-divider">
                  <button type="button"
                          class="scenario-score-reset-button"
                          aria-label="점수 초기화"
                          @onclick="(() => ResetScore(context))">
                    reset
                  </button>
                </MudTd>
                <MudTd Class="scenario-score-cell">
                  <button type="button"
                          class="scenario-score-touch-button"
                          aria-label="@($"{context.AwayTeam.Name} 득점 올리기")"
                          @onclick="(() => OnScoreIncrement(context, false))">
                    @context.AwayScore
                  </button>
                </MudTd>
                <MudTd DataLabel="원정" Class="scenario-team-cell">
                  <div class="scenario-team">
                    @if (!string.IsNullOrWhiteSpace(context.AwayTeam.Flag))
                    {
                      <img src="@context.AwayTeam.Flag" alt="" />
                    }
                    <span>@context.AwayTeam.Name</span>
                  </div>
                </MudTd>
              </RowTemplate>
              <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="scenario-empty">남은 경기가 없습니다.</MudText>
              </NoRecordsContent>
            </MudTable>
          </div>

          <div class="scenario-standings">
            <div class="scenario-panel-title">순위표</div>
            <MudTable T="Wc2026ScenarioStanding"
                      Items="@group.Standings"
                      Dense="true"
                      Hover="true"
                      Breakpoint="Breakpoint.None"
                      Elevation="0"
                      Class="scenario-table scenario-standing-table">
              <HeaderContent>
                <MudTh Class="scenario-rank-cell">#</MudTh>
                <MudTh>국가</MudTh>
                <MudTh Class="scenario-record-cell">승 / 무 / 패</MudTh>
                <MudTh Class="scenario-stat-cell">승점</MudTh>
                <MudTh Class="scenario-stat-cell">골득실</MudTh>
                <MudTh Class="scenario-stat-cell">득점</MudTh>
                <MudTh Class="scenario-stat-cell">실점</MudTh>
              </HeaderContent>
              <RowTemplate>
                <MudTd DataLabel="#" Class="scenario-rank-cell">@context.Rank</MudTd>
                <MudTd DataLabel="국가" Class="scenario-team-cell">
                  <div class="@($"scenario-team scenario-standing-team{(ShouldShowMyPickedTeamMarker() ? " scenario-standing-team-with-marker" : "")}")">
                    @if (IsMyPickedTeam(context.Team))
                    {
                      <span class="team-picked-badge scenario-standing-picked-badge" aria-hidden="true">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                      </span>
                    }
                    @if (!string.IsNullOrWhiteSpace(context.Team.Flag))
                    {
                      <img src="@context.Team.Flag" alt="" />
                    }
                    <span>@context.Team.Name</span>
                  </div>
                </MudTd>
                <MudTd DataLabel="승 / 무 / 패" Class="scenario-record-cell">@context.RecordText</MudTd>
                <MudTd DataLabel="승점" Class="scenario-stat-cell">@context.Points</MudTd>
                <MudTd DataLabel="골득실" Class="scenario-stat-cell">@context.GoalDifference</MudTd>
                <MudTd DataLabel="득점" Class="scenario-stat-cell">@context.GoalsFor</MudTd>
                <MudTd DataLabel="실점" Class="scenario-stat-cell">@context.GoalsAgainst</MudTd>
              </RowTemplate>
            </MudTable>
          </div>
        </div>
      </section>
    }
  </div>
}
