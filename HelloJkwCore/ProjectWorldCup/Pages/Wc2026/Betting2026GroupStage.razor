@inherits JkwPageBase
@layout WcLayout
@using ProjectWorldCup.Pages.Betting;
@page "/worldcup/2026/betting/group-stage"


<WcTitle>1라운드: 각 조 1,2위 맞추기</WcTitle>

@code {
    string commonButtonStyle = "padding: 6px; border-radius: 6px; box-shadow: var(--mud-elevation-1); display: block; text-align: start; width: 100%; text-transform: initial;";
}

@if (BettingItems?.Any() ?? false)
{
    @* <BettingResultComponent BettingItems="BettingItems"></BettingResultComponent> *@
}

@if (!IsAuthenticated)
{
  <MudLink Href="/login?ReturnUrl=/worldcup/2026/betting/group-stage" Underline="Underline.Always">
    &lt;&lt; 로그인 하러 가기 &gt;&gt;
  </MudLink>
}
else if ((BettingUser?.JoinStatus ?? UserJoinStatus.None)== UserJoinStatus.None)
{
  <MudLink Href="/worldcup/2026/welcome-betting" Underline="Underline.Always">
    &lt;&lt; 참가신청 하러 가기 &gt;&gt;
  </MudLink>
}
else
{
  <MudText Typo="Typo.body1" Class="d-block">저장 버튼은 없습니다. 자동 저장 됩니다.</MudText>
  <MudText Typo="Typo.body1" Class="d-block">잘 할 것 같은 팀을 선택하기만 하면 됩니다. 한 조에 두 팀을 고르세요.</MudText>
  <MudText Typo="Typo.body1" Class="d-block">선택을 바꾸고 싶으면 다시 누르면 됩니다.</MudText>
  <MudText Typo="Typo.body1" Class="d-block">AI의 도움을 받고 싶다면 이 버튼을 눌러주세요.</MudText>
  <MudButton OnClick="@OpenAiHelperDialog" Variant="Variant.Outlined" Color="Color.Error" Disabled="@TimeOver" StartIcon="@Icons.Material.Filled.AutoAwesome">
    AI야 도와줘!
  </MudButton>
}

@if (ShowAiHelperDialog)
{
  <MudDialog @bind-Visible="@ShowAiHelperDialog" Options="@AiHelperDialogOptions" ContentClass="ai-helper-dialog-content" ActionsClass="ai-helper-dialog-actions">
    <TitleContent>
      <MudText Typo="Typo.h6">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-2" />
        AI야 도와줘!
      </MudText>
    </TitleContent>
    <DialogContent>
      <MudText Typo="Typo.body2" Class="ai-helper-description">
        아래 프롬프트를 복사해서 AI에게 물어보세요. 그리고 결과를 그대로 복사해서 아래 결과 제출란에 제출하세요.
      </MudText>

      <MudText Typo="Typo.subtitle2" Class="ai-helper-label">프롬프트</MudText>
      <MudTextField T="string"
                    Value="@AiHelpPrompt"
                    ReadOnly="true"
                    Lines="12"
                    Variant="Variant.Outlined"
                    FullWidth="true"
                    Class="ai-helper-textarea" />
      <MudButton OnClick="@CopyAiPromptAsync"
                 Variant="Variant.Outlined"
                 Color="Color.Primary"
                 StartIcon="@Icons.Material.Filled.ContentCopy"
                 Disabled="@IsSubmittingAiResult"
                 Class="ai-helper-copy-button">
        프롬프트 복사
      </MudButton>

      <MudText Typo="Typo.subtitle2" Class="ai-helper-label">결과 제출란</MudText>
      <MudTextField T="string"
                    @bind-Value="@AiResultInput"
                    Placeholder="{ &quot;A조&quot;: [&quot;국가1&quot;, &quot;국가2&quot;], ... }"
                    Lines="12"
                    Variant="Variant.Outlined"
                    FullWidth="true"
                    Class="ai-helper-textarea" />

      @if (!string.IsNullOrWhiteSpace(AiSubmitMessage))
      {
        <MudAlert Severity="@AiSubmitSeverity" Class="ai-helper-alert">
          @AiSubmitMessage
        </MudAlert>
      }
    </DialogContent>
    <DialogActions>
      <MudButton OnClick="@CloseAiHelperDialog" Variant="Variant.Text" Disabled="@IsSubmittingAiResult">
        닫기
      </MudButton>
      <MudButton OnClick="@SubmitAiResultAsync" Variant="Variant.Filled" Color="Color.Primary" Disabled="@IsSubmittingAiResult">
        @(IsSubmittingAiResult ? "저장 중..." : "결과 제출")
      </MudButton>
    </DialogActions>
  </MudDialog>
}

@if (TimeOver)
{
    <div>선택 시간이 끝났습니다.</div>
}
else
{
<WcRemainTime
    ClassName="group-stage-remain-time"
    RemainSeconds="@(GroupStageService.GetRemainSeconds())"
    TimeOver="@(() => OnTimeOver())"/>

<div class="remain-text">
    <span class="group-stage-remain-time"></span>
    <span>남았습니다.</span>
</div>
}

<div>
    @foreach (var group in Groups)
    {
        <div class="group-row">
            <div class="group-name">@group.Name</div>
            <div class="group-teams">
                <div class="teams-row">
                    @foreach (var team in group.Teams)
                    {
<div class="team">
@if (GetButtonType(team) == TeamButtonType.Pickable)
{
    var buttonStyle = $"{commonButtonStyle}";
    <MudButton Class="team-inner" Style="@buttonStyle" OnClick="(async () => await PickTeam(team))">
        <img class="team-img" src="@team?.Flag"/>
        <span class="team-name">@team?.Name</span>
    </MudButton>
}
else if (GetButtonType(team) == TeamButtonType.Picked)
{
    var buttonStyle = $"{commonButtonStyle} color: white; background: #56042C";
    <MudButton Class="team-inner" Style="@buttonStyle" OnClick="(async () => await UnpickTeam(team))">
        <img class="team-img" src="@team?.Flag"/>
        <span class="team-name">@team?.Name</span>
    </MudButton>
}
else
{
    <MudButton Class="team-inner" Style="@commonButtonStyle" Disabled="true">
        <img class="team-img" src="@team?.Flag" style="filter: grayscale(0.7)"/>
        <span class="team-name">@team?.Name</span>
    </MudButton>
}
</div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!TimeOver)
{
  @if (BettingItem?.IsRandom ?? false)
  {
  }
  else
  {
  @if (CheckRandom1 == false)
  {
    <MudButton OnClick="@(() => { CheckRandom1 = true; })" Variant="Variant.Outlined" Color="Color.Error">
      랜덤 선택 (저는 운에 맡기겠어요)
    </MudButton>
  }
  else if (CheckRandom2 == false)
  {
    <MudButton OnClick="@(() => { CheckRandom2 = true; })" Variant="Variant.Outlined" Color="Color.Error">
      랜덤 선택을 하면 더 이상 수정할 수 없습니다. 각오하셨습니까?
    </MudButton>
  }
  else if (CheckRandom3 == false)
  {
    <MudButton OnClick="@(() => { CheckRandom3 = true; })" Variant="Variant.Outlined" Color="Color.Error">
      결과가 마음에 안들더라도 절대 복구해주지 않을 겁니다. 괜찮습니까?
    </MudButton>
  }
  else
  {
    <MudButton OnClick="@(() => SelectFullRandom())" Variant="Variant.Filled" Color="Color.Error">
      찐막 질문. 랜덤 선택하시겠습니까?
    </MudButton>
  }
  }
}
