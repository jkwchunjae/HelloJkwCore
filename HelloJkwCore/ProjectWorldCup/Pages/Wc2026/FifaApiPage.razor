@inherits JkwPageBase
@layout WcLayout
@page "/worldcup/2026/fifa-api"

<WcTitle>FIFA API</WcTitle>

@if (Error != null)
{
  <MudAlert Severity="Severity.Error" Class="fifa-api-alert">
    FIFA API 데이터를 불러오지 못했습니다. @Error.Message
  </MudAlert>
}
else
{
  <MudTabs Rounded="true" @bind-ActivePanelIndex="ActivePanelIndex">
    @foreach (var stage in Stages)
    {
      <MudTabPanel Text="@stage.Title">
        <div class="fifa-api-tab-panel">
          <div class="fifa-api-count">@stage.Rows.Count 경기</div>
          <MudTable T="FifaApiMatchRow"
                    Items="@stage.Rows"
                    Dense="true"
                    Hover="true"
                    FixedHeader="true"
                    Breakpoint="Breakpoint.None"
                    Height="calc(100vh - 285px)"
                    RowClassFunc="@((row, _) => GetInitialScrollRowClass(row))"
                    Class="fifa-api-table">
            <HeaderContent>
              <MudTh Class="fifa-api-number-cell">No.</MudTh>
              <MudTh Class="fifa-api-mobile-stage-cell px-2">조</MudTh>
              <MudTh Class="fifa-api-time-cell">시간 (KST)</MudTh>
              <MudTh Class="fifa-api-mobile-time-cell px-1">시간</MudTh>
              <MudTh Class="fifa-api-stage-cell">단계/조</MudTh>
              <MudTh Class="fifa-api-team-cell">홈</MudTh>
              <MudTh Class="fifa-api-result-cell">결과</MudTh>
              <MudTh Class="fifa-api-team-cell">원정</MudTh>
            </HeaderContent>
            <RowTemplate>
              <MudTd DataLabel="No." Class="fifa-api-number-cell">@context.Number</MudTd>
              <MudTd DataLabel="조" Class="fifa-api-mobile-stage-cell px-2">@context.StageGroupText</MudTd>
              <MudTd DataLabel="시간 (KST)" Class="fifa-api-time-cell">@context.KickoffKst.ToString("yyyy-MM-dd HH:mm")</MudTd>
              <MudTd DataLabel="시간" Class="fifa-api-mobile-time-cell px-1">@context.ShortKickoffText</MudTd>
              <MudTd DataLabel="단계/조" Class="fifa-api-stage-cell">@context.StageGroupText</MudTd>
              <MudTd DataLabel="홈" Class="fifa-api-team-cell">
                <div class="fifa-api-team @(context.HomeIsPlaceholder ? "placeholder" : "")">
                  @if (!string.IsNullOrWhiteSpace(context.HomeFlag))
                  {
                    <img src="@context.HomeFlag" alt="" />
                  }
                  <span>@context.HomeName</span>
                </div>
              </MudTd>
              <MudTd DataLabel="결과" Class="fifa-api-result-cell">
                <span class="fifa-api-result @(context.ResultText == "예정" ? "scheduled" : "")">@context.ResultText</span>
              </MudTd>
              <MudTd DataLabel="원정" Class="fifa-api-team-cell">
                <div class="fifa-api-team @(context.AwayIsPlaceholder ? "placeholder" : "")">
                  @if (!string.IsNullOrWhiteSpace(context.AwayFlag))
                  {
                    <img src="@context.AwayFlag" alt="" />
                  }
                  <span>@context.AwayName</span>
                </div>
              </MudTd>
            </RowTemplate>
          </MudTable>
        </div>
      </MudTabPanel>
    }
  </MudTabs>
}
