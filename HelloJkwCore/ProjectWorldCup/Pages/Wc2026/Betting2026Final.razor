@inherits JkwPageBase
@layout WcLayout
@using ProjectWorldCup.Pages.Betting
@page "/worldcup/2026/betting/final"

@code {
    string commonButtonStyle = "padding: 6px; border-radius: 6px; box-shadow: var(--mud-elevation-1); display: block; text-align: start; width: 100%; text-transform: initial;";
}

<WcTitle>4라운드: 1,2,3,4등 맞추기</WcTitle>

@if (IsAuthenticated && !TimeOver && !(BettingItem?.IsRandom ?? false))
{
    <div class="ai-helper-actions">
        <MudButton OnClick="@OpenAiHelperDialog"
                   Variant="Variant.Outlined"
                   Color="Color.Error"
                   Disabled="@(!CanUseAiHelper || IsSubmittingAiResult)"
                   StartIcon="@Icons.Material.Filled.AutoAwesome">
            @if (AllMatchesAreSetted)
            {
                <span>AI야 도와줘!</span>
            }
            else
            {
                <span>AI야 도와줘: 8강 진출팀이 모두 확정 된 후에 사용가능 합니다.</span>
            }
        </MudButton>
    </div>
}

@if (ShowAiHelperDialog)
{
    <MudDialog @ref="AiHelperDialog" Visible="@ShowAiHelperDialog" VisibleChanged="@OnAiHelperDialogVisibleChanged" Options="@AiHelperDialogOptions" ContentClass="ai-helper-dialog-content" ActionsClass="ai-helper-dialog-actions">
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Class="mr-2" />
                AI야 도와줘!
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body2" Class="ai-helper-description">
                아래 프롬프트를 복사해서 AI에게 물어보세요. 그리고 결과를 그대로 복사해서 아래 결과 제출란에 제출하세요.
            </MudText>

            <MudText Typo="Typo.subtitle2" Class="ai-helper-label">프롬프트</MudText>
            <MudTextField T="string"
                          Value="@AiHelpPrompt"
                          ReadOnly="true"
                          Lines="14"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="ai-helper-textarea" />
            <MudButton OnClick="@CopyAiPromptAsync"
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ContentCopy"
                       Disabled="@IsSubmittingAiResult"
                       Class="ai-helper-copy-button">
                프롬프트 복사
            </MudButton>

            <MudText Typo="Typo.subtitle2" Class="ai-helper-label">결과 제출란</MudText>
            <MudTextField T="string"
                          @bind-Value="@AiResultInput"
                          Placeholder="{ &quot;8강&quot;: { &quot;1경기&quot;: &quot;국가1&quot; }, &quot;4강&quot;: { &quot;1경기&quot;: &quot;국가1&quot; }, &quot;3,4위전&quot;: &quot;국가3&quot;, &quot;결승전&quot;: &quot;국가1&quot; }"
                          Lines="14"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Class="ai-helper-textarea" />

            @if (!string.IsNullOrWhiteSpace(AiSubmitMessage))
            {
                <MudAlert Severity="@AiSubmitSeverity" Class="ai-helper-alert">
                    @AiSubmitMessage
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@CloseAiHelperDialog" Variant="Variant.Text" Disabled="@IsSubmittingAiResult">
                닫기
            </MudButton>
            <MudButton OnClick="@SubmitAiResultAsync" Variant="Variant.Filled" Color="Color.Primary" Disabled="@IsSubmittingAiResult">
                @(IsSubmittingAiResult ? "저장 중..." : "결과 제출")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

<WcRemainTime ClassName="final-remain-time-text"
              RemainSeconds="@((int)(WorldCupConst.Round8StartTime - DateTime.Now).TotalSeconds)"
              TimeOver="@(() => TimeOver = true)" />

@if (TimeOver && (BettingItems?.Any() ?? false))
{
    <BettingFinalResultComponent BettingItems="BettingItems" Visible="@TimeOver"></BettingFinalResultComponent>
}

<div class="desc">
    <MudText Typo="Typo.body1" Class="d-block">8강 첫 경기가 시작하기 전에 우승팀까지 선택해야 합니다</MudText>
    <MudText Typo="Typo.body1" Class="d-block">계속 선택하다보면 결승전이 나타납니다.</MudText>

    @if (TimeOver)
    {
        <div>
            <span>선택 시간이 끝났습니다.</span>
        </div>
    }
    else
    {
        <div>
            <span class="final-remain-time-text"></span>
            <span>남았습니다</span>
        </div>
    }
</div>

@foreach (var stageData in StageMatches)
{
    string stageId = stageData.StageId;
    var matches = stageData.Matches;

    <div class="matches">
        <div class="stage-name">
            <MudText Typo="Typo.h5">@StageName[stageId]</MudText>
        </div>
        @foreach (var matchData in matches)
        {
            var matchId = matchData?.MatchId;
            var homeType = GetButtonType(stageId, matchData?.HomeTeam);
            var awayType = GetButtonType(stageId, matchData?.AwayTeam);
            var homeButtonStyle = homeType == TeamButtonType.Picked ? $"{commonButtonStyle} color: white; background: #56042C"
            : commonButtonStyle;
            var awayButtonStyle = awayType == TeamButtonType.Picked ? $"{commonButtonStyle} color: white; background: #56042C"
            : commonButtonStyle;

            <div class="match-row">
                <div class="team">
                    <MudButton Class="@($"team-inner{(homeType == TeamButtonType.Picked ? " team-picked" : "")}")" Style="@homeButtonStyle" OnClick="(async () => await PickTeamAsync(stageId, matchId, matchData?.HomeTeam))" Disabled="@(homeType == TeamButtonType.Disabled)">
                        @if (homeType == TeamButtonType.Picked)
                        {
                            <span class="team-picked-badge" aria-hidden="true">
                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                            </span>
                        }
                        <img class="team-img" src="@matchData?.HomeTeam?.Flag" />
                        <span class="team-name">@matchData?.HomeTeam?.Name</span>
                    </MudButton>
                </div>
                <div class="team">
                    <MudButton Class="@($"team-inner{(awayType == TeamButtonType.Picked ? " team-picked" : "")}")" Style="@awayButtonStyle" OnClick="(async () => await PickTeamAsync(stageId, matchId, matchData?.AwayTeam))" Disabled="@(awayType == TeamButtonType.Disabled)">
                        @if (awayType == TeamButtonType.Picked)
                        {
                            <span class="team-picked-badge" aria-hidden="true">
                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                            </span>
                        }
                        <img class="team-img" src="@matchData?.AwayTeam?.Flag" />
                        <span class="team-name">@matchData?.AwayTeam?.Name</span>
                    </MudButton>
                </div>
            </div>
        }
    </div>
}
@if (!TimeOver)
{
    @if (BettingItem?.IsRandom ?? false)
    {
    }
    else if (!AllMatchesAreSetted)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error">
            랜덤 선택: 8강 진출팀이 모두 확정 된 후에 선택가능 합니다.
        </MudButton>
    }
    else
    {
        @if (CheckRandom1 == false)
        {
            <MudButton OnClick="@(() => { CheckRandom1 = true; })" Variant="Variant.Outlined" Color="Color.Error">
                랜덤 선택
            </MudButton>
        }
        else if (CheckRandom2 == false)
        {
            <MudButton OnClick="@(() => { CheckRandom2 = true; })" Variant="Variant.Outlined" Color="Color.Error">
                랜덤 선택을 하면 더 이상 수정할 수 없습니다. 각오하셨습니까?
            </MudButton>
        }
        else if (CheckRandom3 == false)
        {
            <MudButton OnClick="@(() => { CheckRandom3 = true; })" Variant="Variant.Outlined" Color="Color.Error">
                결과가 마음에 안들더라도 절대 복구해주지 않을 겁니다. 괜찮습니까?
            </MudButton>
        }
        else
        {
            <MudButton OnClick="@(() => SelectFullRandom())" Variant="Variant.Filled" Color="Color.Error">
                찐막 질문. 랜덤 선택하시겠습니까?
            </MudButton>
        }
    }
}

<BettingFinalResultComponent BettingItems="BettingItems" Visible="true"></BettingFinalResultComponent>
